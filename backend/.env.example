# --- Server ---
PORT=5000
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://user:pass@localhost:5432/chatbot

# --- JWT ---
JWT_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_long_random_string
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# --- Security (Salt + Pepper) ---
# Long random string. Combined with bcrypt salt via HMAC-SHA256.
# CHANGING THIS INVALIDATES ALL EXISTING PASSWORDS.
PASSWORD_PEPPER=replace_me_with_a_very_long_random_pepper_string

# --- Gemini ---
GEMINI_API_KEY=your_gemini_api_key

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
OAUTH_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# --- Credits ---
DEFAULT_USER_CREDITS=100
CREDIT_COST_TEXT=0.1
CREDIT_COST_IMAGE=0.5
CREDIT_COST_AUDIO=0.3
